{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "start": "next start",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "db:dev": "docker compose -f docker-compose.dev.yml up -d",
    "db:dev:stop": "docker compose -f docker-compose.dev.yml down",
    "db:migrate": "dotenv -e .env.development -- prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "dotenv -e .env.development -- prisma db push",
    "db:seed": "dotenv -e .env.development -- prisma db seed",
    "db:studio": "dotenv -e .env.development -- prisma studio",
    "db:reset": "dotenv -e .env.development -- prisma migrate reset",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.2",
    "@excalidraw/excalidraw": "^0.18.0",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/client": "^6.0.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tiptap/core": "^3.20.0",
    "@tiptap/extension-highlight": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/extension-text-align": "^3.20.0",
    "@tiptap/extension-text-style": "^3.20.0",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@tiptap/suggestion": "^3.20.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.555.0",
    "motion": "^12.34.3",
    "next": "16.1.5",
    "next-auth": "^5.0.0-beta.25",
    "next-themes": "^0.4.4",
    "nodemailer": "^7.0.11",
    "react": "19.2.3",
    "react-activity-calendar": "^3.1.1",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "tiptap-extension-global-drag-handle": "^0.1.18",
    "zustand": "^5.0.11"
  },
  "pnpm": {
    "overrides": {
      "dompurify": ">=3.2.4",
      "mermaid": ">=10.9.4",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "nanoid@>=3.0.0 <4.0.0": ">=3.3.8",
      "nanoid@>=4.0.0 <5.0.9": ">=5.0.9",
      "nanoid": ">=5.0.9",
      "nodemailer@<=7.0.10": ">=7.0.11"
    }
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-a11y": "^10.2.13",
    "@storybook/addon-docs": "^10.2.13",
    "@storybook/addon-onboarding": "^10.2.13",
    "@storybook/addon-themes": "^10.2.13",
    "@storybook/addon-vitest": "^10.2.13",
    "@storybook/nextjs-vite": "^10.2.13",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/dom-speech-recognition": "^0.0.7",
    "@types/node": "^25.3.2",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-sonarjs": "^4.0.0",
    "eslint-plugin-storybook": "^10.2.13",
    "eslint-plugin-unused-imports": "^4.4.1",
    "happy-dom": "^20.7.0",
    "knip": "^5.85.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^6.19.2",
    "storybook": "^10.2.13",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
